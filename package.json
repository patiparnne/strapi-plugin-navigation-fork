{
  "name": "strapi-plugin-navigation-fork",
  "version": "0.1.1",
  "description": "Strapi Navigation plugin fork — multi-language slug support, path structure customization, and import/export features",
  "strapi": {
    "name": "navigation",
    "displayName": "Navigation (Fork)",
    "description": "Navigation builder with multi-language slug, path structure, and import/export support",
    "kind": "plugin"
  },
  "dependencies": {
    "@sensinum/strapi-utils": "^1.0.10",
    "@sindresorhus/slugify": "1.1.0",
    "pluralize": "8.0.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "uuid": "^10.0.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@jest/types": "29.5.x",
    "@koa/router": "^12.0.1",
    "@strapi/plugin-graphql": "5.33.0",
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "5.33.0",
    "@strapi/types": "5.33.0",
    "@strapi/typescript-utils": "5.33.0",
    "@types/jest": "^29.5.12",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__router": "^12.0.4",
    "@types/lodash": "^4.17.4",
    "@types/node": "^20.12.0",
    "@types/pluralize": "0.0.33",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "5.3.3",
    "@types/uuid": "^10.0.0",
    "codecov": "^3.7.2",
    "husky": "7.0.4",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-styled-components": "^7.1.1",
    "koa": "^3.0.1",
    "lodash": "^4.17.21",
    "nodemon": "^2.0.15",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-query": "3.39.3",
    "react-router-dom": "^6.22.3",
    "styled-components": "6.1.8",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@strapi/sdk-plugin": "^5.0.0",
    "@strapi/strapi": "^5.0.0",
    "@strapi/admin": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "lodash": "^4.17.21",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-intl": "^6.0.0 || ^7.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "zod": "3.25.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn format && yarn test:unit"
    }
  },
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "publish:latest": "npm publish --tag latest",
    "publish:beta": "npm publish --tag beta",
    "build": "strapi-plugin build --minify",
    "build:admin:watch": "tsc -p ./admin/tsconfig.json --watch",
    "build:server:watch": "tsc -p ./server/tsconfig.json --watch",
    "clean": "rm -rf dist",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test:ts:back": "run -T tsc -p server/tsconfig.json",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:unit": "jest --coverage",
    "test:unit:watch": "jest --watch",
    "test:unit:ci": "CI=true jest --ci --runInBand --verbose --coverage",
    "verify": "strapi-plugin verify",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link"
  },
  "keywords": [
    "strapi",
    "plugin",
    "navigation",
    "fork",
    "multi-language",
    "slug",
    "import-export"
  ],
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/patiparnne/strapi-plugin-navigation-fork.git"
  },
  "bugs": {
    "url": "https://github.com/patiparnne/strapi-plugin-navigation-fork/issues"
  },
  "homepage": "https://github.com/patiparnne/strapi-plugin-navigation-fork#readme",
  "author": "Patiparnne <patiparnne@gmail.com>",
  "buy_me_a_coffee": "https://buymeacoffee.com/patiparnne",
  "patreon": "https://www.patreon.com/patiparnne",
  "packageManager": "yarn@4.6.0"
}
